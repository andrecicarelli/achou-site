---
layout: base.njk
---
<article class="post-wrapper">
  <div class="container">

    <nav class="breadcrumb" aria-label="Navegação">
      <a href="/">Início</a>
      <span aria-hidden="true">›</span>
      <a href="/blog/">Blog</a>
      <span aria-hidden="true">›</span>
      <span>{{ title }}</span>
    </nav>

    <header class="post-header">
      <div class="post-meta">
        <time datetime="{{ date | dateIso }}">{{ date | dateFormat }}</time>
        <span aria-hidden="true">·</span>
        <span>{{ content | readingTime }} min de leitura</span>
      </div>
      <h1>{{ title }}</h1>
      {% if description %}
      <p class="post-lead">{{ description }}</p>
      {% endif %}
    </header>

    <div class="post-body">
      {{ content | safe }}
    </div>

    <aside class="post-cta-box">
      <p class="post-cta-label">Quer o seu negócio aparecendo no Google?</p>
      <h3>A Achou cuida do seu site e da sua presença digital. Você foca no trabalho.</h3>
      <p>Fale com a gente pelo WhatsApp — sem compromisso.</p>
      <a href="{{ site.whatsapp }}" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Falar no WhatsApp →</a>
    </aside>

    {% set related = collections.publishedPosts | relatedPosts(page.url) %}
    {% if related and related.length %}
    <section class="post-related">
      <h2>Continue lendo</h2>
      <div class="posts-grid posts-grid--sm">
        {% for post in related %}
          <a href="{{ post.url }}" class="post-card">
            <div class="post-card-meta">
              <time datetime="{{ post.date | dateIso }}">{{ post.date | dateFormat }}</time>
              <span>· {{ post.templateContent | readingTime }} min</span>
            </div>
            <h3>{{ post.data.title }}</h3>
            {% if post.data.description %}
            <p>{{ post.data.description }}</p>
            {% endif %}
            <span class="post-card-link">Ler artigo →</span>
          </a>
        {% endfor %}
      </div>
    </section>
    {% endif %}

  </div>
</article>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "{{ title | escape }}",
  "description": "{{ description | escape }}",
  "datePublished": "{{ date | dateIso }}",
  "dateModified": "{{ date | dateIso }}",
  "url": "{{ site.url }}{{ page.url }}",
  "author": {
    "@type": "Organization",
    "name": "{{ site.name }}"
  },
  "publisher": {
    "@type": "Organization",
    "name": "{{ site.name }}",
    "url": "{{ site.url }}"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ site.url }}{{ page.url }}"
  }
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Início", "item": "{{ site.url }}/" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "{{ site.url }}/blog/" },
    { "@type": "ListItem", "position": 3, "name": "{{ title | escape }}", "item": "{{ site.url }}{{ page.url }}" }
  ]
}
</script>
