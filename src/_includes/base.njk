<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>{% if title %}{{ title }} — {% endif %}{{ site.name }}</title>
  <meta name="description" content="{{ description or site.description }}" />
  <link rel="canonical" href="{{ site.url }}{{ page.url }}" />

  <!-- Open Graph -->
  <meta property="og:title" content="{% if title %}{{ title }} — {% endif %}{{ site.name }}" />
  <meta property="og:description" content="{{ description or site.description }}" />
  <meta property="og:url" content="{{ site.url }}{{ page.url }}" />
  <meta property="og:site_name" content="{{ site.name }}" />
  <meta property="og:locale" content="pt_BR" />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="{{ site.url }}/assets/favicon.svg" />

  <!-- Twitter/X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{% if title %}{{ title }} — {% endif %}{{ site.name }}" />
  <meta name="twitter:description" content="{{ description or site.description }}" />
  <meta name="twitter:image" content="{{ site.url }}/assets/favicon.svg" />

  <!-- JSON-LD (valores escapados via site.js, sem interpolação direta) -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Achou",
    "description": "Seu negócio no Google. Nós cuidamos do resto.",
    "url": "https://achouagencia.com.br",
    "address": { "@type": "PostalAddress", "addressCountry": "BR" }
  }
  </script>

  <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />
  <link rel="stylesheet" href="/assets/achou.css?v={{ build.ts }}" />
</head>
<body>

<!-- ── NAVBAR ── -->
<nav class="site-nav" id="site-nav">
  <div class="nav-inner">
    <a href="/" class="logo">achou<span class="logo-dot"></span></a>

    <div class="nav-links" id="nav-links">
      <a href="/#como-funciona" class="nav-link">Como funciona</a>
      <a href="/#planos" class="nav-link">Planos</a>
      <a href="/blog/" class="nav-link">Blog</a>
      <a href="/#faq" class="nav-link">FAQ</a>
    </div>

    <a href="/#contato" class="btn btn-primary nav-cta">Solicitar contato</a>

    <button class="nav-hamburger" id="nav-hamburger" aria-label="Abrir menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="nav-drawer" id="nav-drawer" aria-hidden="true">
    <a href="/#como-funciona" class="nav-drawer-link">Como funciona</a>
    <a href="/#planos" class="nav-drawer-link">Planos</a>
    <a href="/blog/" class="nav-drawer-link">Blog</a>
    <a href="/#faq" class="nav-drawer-link">FAQ</a>
    <a href="/#contato" class="btn btn-primary nav-drawer-cta">Solicitar contato</a>
  </div>
</nav>

{{ content | safe }}

<!-- ── FOOTER ── -->
<footer>
  <div class="container">
    <div class="footer-inner">
      <div>
        <a href="/" class="footer-logo">achou<span class="logo-dot logo-dot--sm"></span></a>
        <p class="footer-tagline">Seu negócio no Google. Nós cuidamos do resto.</p>
      </div>
      <ul class="footer-links">
        <li><a href="/#planos">Planos</a></li>
        <li><a href="/#faq">FAQ</a></li>
        <li><a href="{{ site.whatsapp }}" target="_blank" rel="noopener noreferrer">Contato</a></li>
      </ul>
    </div>
    <p class="footer-copy">© {{ build.year }} Achou — achouagencia.com.br</p>
  </div>
</footer>

  <script src="/assets/achou.js?v={{ build.ts }}" defer></script>

</body>
</html>
